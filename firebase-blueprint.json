{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "When the user last logged in" }
      },
      "required": ["uid", "email"]
    },
    "AppState": {
      "title": "App State",
       "description": "The complete state of the user's Younesslifehub application",
      "type": "object",
      "properties": {
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "tasks": { "type": "array", "items": { "type": "object" } },
        "lessons": { "type": "array", "items": { "type": "object" } },
        "classTemplates": { "type": "array", "items": { "type": "object" } },
        "duas": { "type": "array", "items": { "type": "object" } },
        "transactions": { "type": "array", "items": { "type": "object" } },
        "habits": { "type": "array", "items": { "type": "object" } },
        "brainDump": { "type": "array", "items": { "type": "object" } },
        "meals": { "type": "object" },
        "quran": { "type": "object" },
        "sunnahs": { "type": "object" },
        "adhkarLog": { "type": "object" },
        "ramadanMode": { "type": "boolean" },
        "ramadanLog": { "type": "object" },
        "khatam": { "type": "array", "items": { "type": "boolean" } },
        "qada": { "type": "object" },
        "waterIntake": { "type": "object" },
        "mood": { "type": "object" },
        "steps": { "type": "object" },
        "reading": { "type": "array", "items": { "type": "object" } },
        "badHabits": { "type": "array", "items": { "type": "object" } },
        "goals": { "type": "array", "items": { "type": "object" } },
        "exercises": { "type": "array", "items": { "type": "object" } },
        "scheduleSettings": { "type": "object" },
        "muhasabah": { "type": "array", "items": { "type": "object" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles stored by their UID"
    },
    "/users/{userId}/data/appState": {
      "schema": "AppState",
      "description": "The user's complete application state"
    }
  }
}
